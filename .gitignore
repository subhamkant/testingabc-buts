# Downloaded YouTube videos at repo root (used for review only)
/*.mp4

# Sensitive auth files — NEVER commit these
token.pickle
token_base64.txt
client_secrets.json
client_secrets_1.json
kaggle.json

# Per-render Kaggle batch config (written into the kernel folder by
# pipeline/image_generator.py just before `kaggle kernels push`). Stays
# local — uploads to Kaggle along with the notebook code, never to git.
kaggle_notebooks/*/current_run.json

# Kaggle Dataset payloads (large binary weights staged for upload to Kaggle;
# the metadata + README under kaggle_datasets/*/ IS tracked, just not the
# actual safetensors / mp4 / weight files)
kaggle_datasets/*/*.safetensors
kaggle_datasets/*/*.bin
kaggle_datasets/*/*.pt
kaggle_datasets/*/*.ckpt

# Generated outputs
temp/
output/
logs/
video_log_001.txt
# Local-test artifacts (smoke renders, preview videos, log captures)
preview/

# Offline long-form drivers — personal topic seeds, one-shot config per
# video; the reusable modules they import (pipeline/longform_assembler.py,
# pipeline/shorts_slicer.py) ARE tracked in git. Drivers are not.
whatif_longform_hindi.py
whatif_iran_cables.py
whatif_shorts_from_longform.py
make_internet_24h_script.py
whatif_archive_purge.py

# WhatIf videos moved to a separate channel — downloaded copies live here
# (102 MB, 16 files). Not for git.
whatif_archive/

# Runtime caches (regenerable, no point committing)
trending_cache.json
temp/trending_cache.json

# Per-run pipeline checkpoint cache (uploaded as a GHA artifact for retries,
# not committed back to the repo — regenerable per-run state)
cache/

# Runtime state
.env
scheduled_topics.txt

# Music files — stored in GitHub Release, not in repo
assets/*.mp3
assets/music/

# EXCEPTION: dark_ambient.mp3 is procedurally synthesized (see
# tools/synthesize_ambient_bed.py), guaranteed Content-ID-safe, and small
# enough (~1 MB) to track in git. Tracking it means GHA cron gets the
# ambient bed automatically without needing to update the music-tracks
# release.
!assets/dark_ambient.mp3

# Claude Code internal
.claude/

# Phase 22 (2026-06-25) — quarantine dumps for scripts that fail
# strict-pass (score < 25/25). Auto-grown by main.py:_phase22_quarantine_if_needed.
#
# Phase 22.2 hotfix (2026-06-26): pattern was `_quarantine/` which is a
# directory exclusion — gitignore CANNOT re-include children of an excluded
# directory (well-known gotcha, see git-scm.com/docs/gitignore). The
# `!_quarantine/scripts/*.json` exception silently no-op'd; run
# 28194021676's JSON dump was written on the runner but never staged.
# Pattern is now `_quarantine/*` (matches the FILES inside, not the dir
# itself) so the negation exceptions take effect.
_quarantine/*
!_quarantine/scripts/
!_quarantine/scripts/*.json

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
